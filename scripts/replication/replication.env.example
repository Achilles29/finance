# Konfigurasi Replication — tambahkan ke scripts/backup/.env

# Role server ini: MASTER, SLAVE, atau STANDALONE
SERVER_ROLE=SLAVE

# Alamat Server 1 (Master)
MASTER_HOST=IP_ATAU_DOMAIN_SERVER_1
MASTER_PORT=3306

# User replication (dibuat saat setup_master.sh)
REPL_USER=repl_user
REPL_PASS=repl_password_ganti_ini

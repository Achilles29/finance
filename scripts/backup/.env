# ============================================================
# Konfigurasi Backup — salin ke .env dan sesuaikan nilainya
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=db_finance

# --- Path ---
# Relatif dari finance/ atau absolute path
BACKUP_DIR=backup/dumps
LOG_DIR=backup/logs

# --- Retention ---
# Berapa hari backup disimpan di lokal sebelum dihapus
RETENTION_DAYS=3

# --- GitHub ---
# Repo khusus backup (beda dari repo app, supaya tidak mix)
# Contoh: git@github.com:username/finance-backup.git
BACKUP_REPO_REMOTE=origin
BACKUP_REPO_BRANCH=main

# Jika backup repo terpisah, set path lokal repo-nya
# Kosongkan jika sama dengan repo utama app
BACKUP_REPO_PATH=

# --- Mode ---
# full  = dump semua tabel (default, untuk backup reguler)
# partial = hanya tabel kunci (lebih cepat, untuk health check)
BACKUP_MODE=full

# Tabel yang DIKECUALIKAN dari dump (pisahkan koma, tanpa spasi)
# Contoh tabel log besar yang tidak kritis untuk restore cepat
EXCLUDE_TABLES=sys_audit_log,att_presence

# Wajib
CF_API_TOKEN=isi_token_api_cloudflare
CF_ZONE_ID=isi_zone_id_cloudflare

# Default hanya update record A, jadi Tunnel otomatis tidak tersentuh.
CF_RECORD_TYPES=A

# Jika kosong, semua record A dalam zone akan diproses.
# Jika zona dipakai multi-server, isi host yang memang milik server ini.
# Contoh:
# CF_INCLUDE_NAMES=absen.namuacoffee.com,cloud.namuacoffee.com,dashboard.namuacoffee.com
CF_INCLUDE_NAMES=

# Host yang harus dilewati walaupun ada di zone dan bertipe A.
# Contoh:
# CF_EXCLUDE_NAMES=finance.namuacoffee.com,game.namuacoffee.com
CF_EXCLUDE_NAMES=

# Jika ada duplikat A record dengan nama sama dan update mentok karena
# "An identical record already exists", set 1 untuk menghapus duplikat lama.
CF_DELETE_IDENTICAL_CONFLICTS=0

# Opsional
CF_CACHE_FILE=/www/wwwroot/finance/backup/cloudflare/public_ipv4.txt
CF_LOCK_DIR=/tmp/finance-cloudflare-ddns.lock
